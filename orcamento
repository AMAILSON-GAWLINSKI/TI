      const sourceValid = clientSource.value !== '';
      
      if (!phoneValid) {
        clientPhone.classList.add('required-error');
      } else {
        clientPhone.classList.remove('required-error');
      }
      if (!nameValid) {
        clientName.classList.add('required-error');
      } else {
        clientName.classList.remove('required-error');
      }
      if (!sourceValid) {
        clientSource.classList.add('required-error');
      } else {
        clientSource.classList.remove('required-error');
      }
      
      return nameValid && phoneValid && sourceValid;
    }
