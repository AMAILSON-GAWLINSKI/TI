    function calcularSubtotalItens() { 
      let total=0; 
      for(let item of orcamentos){ 
        let base=0;
        if(item.tipo==='lente') base = item.valorLente||0;
        else if(item.tipo==='armacao') base = item.valorArmacao||0;
        else if(item.tipo==='relogio') base = item.valorRelogio||0;
        else if(item.tipo==='joias') base = item.valorJoia||0;
        total+=Math.max(0,base-(item.descontoItem||0)); 
      } 
      return total; 
    }
    
    function calcularTotalFinal() { 
      let desconto = parseCurrency(descontoGeralInput?.value || '0');
      return Math.max(0, calcularSubtotalItens() - desconto); 
    }
    
