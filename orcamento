    function formatPhoneForWhatsApp(phone) {
      let cleaned = phone.replace(/\D/g, '');
      if(cleaned.length === 0) return '';
      if(cleaned.length === 10) cleaned = '55' + cleaned;
      else if(cleaned.length === 11) cleaned = '55' + cleaned;
      else if(cleaned.length === 12 && cleaned.startsWith('55')) cleaned = cleaned;
      else if(cleaned.length === 13 && cleaned.startsWith('55')) cleaned = cleaned;
      else cleaned = '55' + cleaned;
      return cleaned;
    }
    
