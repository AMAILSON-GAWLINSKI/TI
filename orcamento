    function updateOrcamentoField(id, field, value) {
      const item = orcamentos.find(o=>o.id===id); 
      if(!item) return;
      
      if(field==='tipo') item.tipo=value;
      else if(field==='produto') item.produto=value;
      else if(field==='marca') item.marca=value;
      else if(field==='referencia') item.referencia=value;
      else if(field==='materialLente') item.materialLente=value;
      else if(field==='antirreflexo') item.antirreflexo=value;
      else if(field==='filtroLuzAzul') item.filtroLuzAzul=value;
      else if(field==='lenteFotocromatica') item.lenteFotocromatica=value;
      else if(field==='valorLente') { 
        item.valorLenteStr = value; 
        item.valorLente = parseCurrency(value); 
      }
      else if(field==='nomeArmacao') item.nomeArmacao=value;
      else if(field==='materialArmacao') item.materialArmacao=value;
      else if(field==='valorArmacao') { 
        item.valorArmacaoStr = value; 
        item.valorArmacao = parseCurrency(value); 
      }
      else if(field==='nomeRelogio') item.nomeRelogio=value;
      else if(field==='marcaRelogio') item.marcaRelogio=value;
      else if(field==='valorRelogio') { 
        item.valorRelogioStr = value; 
        item.valorRelogio = parseCurrency(value); 
      }
      else if(field==='descricaoJoia') item.descricaoJoia=value;
      else if(field==='tipoJoia') item.tipoJoia=value;
      else if(field==='valorJoia') { 
        item.valorJoiaStr = value; 
        item.valorJoia = parseCurrency(value); 
      }
      else if(field==='descontoItem') { 
        item.descontoItemStr = value; 
