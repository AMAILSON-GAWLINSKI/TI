    function carregarOrcamentoParaEdicao(orcamento) {
      modoEdicao = true;
      orcamentoEditandoId = orcamento.id;
      currentOrcamentoId = orcamento.id;
      jaPassouStep1 = true;
      
      let novoAtendente = null;
      const usuarioSalvo = localStorage.getItem('usuarioLogado');
      if (usuarioSalvo) {
        try {
          const user = JSON.parse(usuarioSalvo);
          novoAtendente = user.nome;
        } catch(e) {}
      }
      if (novoAtendente && atendentes.some(a => a.nome === novoAtendente && a.ativo === true)) {
        atendenteSelect.value = novoAtendente;
      } else {
        atendenteSelect.value = orcamento.atendente;
      }
      
      clientName.value = orcamento.cliente;
      clientAge.value = orcamento.idade || '';
      clientPhone.value = orcamento.telefone || '';
      clientSource.value = orcamento.origem || '';
      if (clientSource.value === 'Concorrente' && orcamento.concorrente) {
        document.getElementById('concorrenteGroup').style.display = 'block';
        document.getElementById('concorrenteNome').value = orcamento.concorrente;
      }
      
      orcamentos = JSON.parse(JSON.stringify(orcamento.itens));
      nextId = orcamentos.length + 1;
      
      if(descontoGeralInput) descontoGeralInput.value = formatMoneyWithThousand(orcamento.descontoGeral || 0);
      
      updateNavButtons();
