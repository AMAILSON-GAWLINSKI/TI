    async function syncPendingData() {
      const pending = JSON.parse(localStorage.getItem('pendingSync') || '[]');
      if (pending.length === 0) return;
      
      showLoading();
      let successCount = 0;
      
      for (const data of pending) {
        try {
          const { error } = await supabase
            .from('orcamentos')
            .upsert({
              id: data.id,
              cliente: data.cliente,
              idade: data.idade,
              telefone: data.telefone,
              atendente: data.atendente,
              origem: data.origem,
              concorrente: data.concorrente || '',
              itens: JSON.stringify(data.itens),
              subtotal: data.subtotal,
              desconto_geral: data.descontoGeral,
              total_final: data.totalFinal,
              status: data.status,
              justificativa: data.justificativa || '',
              data_raw: data.dataRaw,
              created_at: data.dataRaw
            }, { onConflict: 'id' });
          
          if (!error) successCount++;
        } catch(e) {
          console.error('Erro ao sincronizar:', e);
        }
      }
      
      if (successCount === pending.length) {
        localStorage.removeItem('pendingSync');
        await carregarHistoricoDoSupabase();
      }
      hideLoading();
    }
    
    async function salvarComFallback(orcamentoData) {
      if (navigator.onLine) {
        try {
          const { error } = await supabase
            .from('orcamentos')
            .upsert({
              id: orcamentoData.id,
              cliente: orcamentoData.cliente,
              idade: orcamentoData.idade,
              telefone: orcamentoData.telefone,
              atendente: orcamentoData.atendente,
              origem: orcamentoData.origem,
              concorrente: orcamentoData.concorrente || '',
              itens: JSON.stringify(orcamentoData.itens),
              subtotal: orcamentoData.subtotal,
              desconto_geral: orcamentoData.descontoGeral,
              total_final: orcamentoData.totalFinal,
              status: orcamentoData.status,
              justificativa: orcamentoData.justificativa || '',
              data_raw: orcamentoData.dataRaw,
              created_at: orcamentoData.dataRaw
            }, { onConflict: 'id' });
          
          if (!error) {
            await carregarHistoricoDoSupabase();
            return true;
          } else {
            throw error;
          }
        } catch(error) {
          console.error('Erro ao salvar no Supabase, salvando localmente:', error);
          addToPendingSync(orcamentoData);
          return true;
        }
      } else {
        addToPendingSync(orcamentoData);
        return true;
      }
    }
    
    function addToPendingSync(orcamentoData) {
      const pending = JSON.parse(localStorage.getItem('pendingSync') || '[]');
      const existingIndex = pending.findIndex(p => p.id === orcamentoData.id);
      if (existingIndex !== -1) {
        pending[existingIndex] = orcamentoData;
      } else {
        pending.push(orcamentoData);
      }
      localStorage.setItem('pendingSync', JSON.stringify(pending));
      
      const localIndex = historicoOrcamentosGlobal.findIndex(h => h.id === orcamentoData.id);
      if (localIndex !== -1) {
        historicoOrcamentosGlobal[localIndex] = orcamentoData;
      } else {
        historicoOrcamentosGlobal.unshift(orcamentoData);
      }
      localStorage.setItem('historicoOrcamentos', JSON.stringify(historicoOrcamentosGlobal));
    }
    
    function showLoading() {
      let loading = document.querySelector('.loading-overlay');
      if (!loading) {
        loading = document.createElement('div');
        loading.className = 'loading-overlay';
        loading.innerHTML = '<div class="loading-spinner"><i class="fas fa-spinner"></i> Carregando...</div>';
        document.body.appendChild(loading);
      }
      loading.style.display = 'flex';
    }
    
    function hideLoading() {
      const loading = document.querySelector('.loading-overlay');
      if (loading) loading.style.display = 'none';
    }
    
    async function carregarHistoricoDoSupabase() {
      showLoading();
      try {
        if (!navigator.onLine) {
          const localData = localStorage.getItem('historicoOrcamentos');
          if (localData) historicoOrcamentosGlobal = JSON.parse(localData);
          hideLoading();
          return;
        }
        
        const { data, error } = await supabase
          .from('orcamentos')
          .select('*')
          .order('created_at', { ascending: false });
        
        if (error) throw error;
        
        historicoOrcamentosGlobal = data.map(item => ({
          ...item,
          itens: typeof item.itens === 'string' ? JSON.parse(item.itens) : item.itens,
          totalFinal: item.total_final,
          descontoGeral: item.desconto_geral,
          dataRaw: item.data_raw || item.created_at,
          data: new Date(item.created_at).toLocaleString('pt-BR')
        }));
        
        localStorage.setItem('historicoOrcamentos', JSON.stringify(historicoOrcamentosGlobal));
      } catch (error) {
        console.error('Erro ao carregar do Supabase:', error);
        const localData = localStorage.getItem('historicoOrcamentos');
        if (localData) historicoOrcamentosGlobal = JSON.parse(localData);
      } finally {
        hideLoading();
      }
    }
    
    async function deletarOrcamentoDoSupabase(id) {
      showLoading();
      try {
        if (navigator.onLine) {
          const { error } = await supabase
            .from('orcamentos')
            .delete()
            .eq('id', id);
          
          if (error) throw error;
          await carregarHistoricoDoSupabase();
        } else {
          historicoOrcamentosGlobal = historicoOrcamentosGlobal.filter(item => item.id !== id);
          localStorage.setItem('historicoOrcamentos', JSON.stringify(historicoOrcamentosGlobal));
          const pendingDeletes = JSON.parse(localStorage.getItem('pendingDeletes') || '[]');
          if (!pendingDeletes.includes(id)) pendingDeletes.push(id);
          localStorage.setItem('pendingDeletes', JSON.stringify(pendingDeletes));
        }
        return true;
      } catch (error) {
        console.error('Erro ao deletar:', error);
        return false;
      } finally {
        hideLoading();
      }
    }
    
