            html += `<div class="justificativa-list"><i class="fas fa-times-circle" style="color:#e74c3c"></i> <strong>${escapeHtml(j.cliente)}</strong> (${j.data}) — Valor: ${formatMoneyWithSymbol(j.valor)}<br>📌 Motivo: ${escapeHtml(j.motivo)}<br>🆔 ID: ${j.id}</div>`;
          }
        }
      }
      if (!hasJustificativas) {
        html += `<div class="justificativa-list" style="background:#f1f5f9;">Nenhum orçamento não finalizado com justificativa registrada até o momento.</div>`;
      }
      
      container.innerHTML = html;
      
      if (mesesLabels.length > 0) {
        setTimeout(() => {
          const ctxLine = document.getElementById('monthlyCompareChart')?.getContext('2d');
          const ctxBar = document.getElementById('lostValueChart')?.getContext('2d');
          if (ctxLine) {
            new Chart(ctxLine, {
              type: 'line',
              data: { labels: mesesLabels, datasets: [{ label: 'Vendas fechadas', data: vendasCount, borderColor: '#25d366', backgroundColor: 'rgba(37,211,102,0.1)', tension: 0.3, fill: true }, { label: 'Orçamentos não finalizados', data: perdidosCount, borderColor: '#e74c3c', backgroundColor: 'rgba(231,76,60,0.05)', tension: 0.3, fill: true }] },
              options: { responsive: true, maintainAspectRatio: true }
            });
          }
          if (ctxBar) {
            new Chart(ctxBar, {
              type: 'bar',
              data: { labels: mesesLabels, datasets: [{ label: 'Valor perdido (R$)', data: valorPerdidoMensal, backgroundColor: '#fc5404', borderRadius: 10 }] },
              options: { responsive: true, maintainAspectRatio: true, plugins: { tooltip: { callbacks: { label: (ctx) => `R$ ${ctx.raw.toFixed(2)}` } } } }
            });
          }
        }, 100);
      }
      
      const btnExcluirSelecionados = document.getElementById('btnExcluirSelecionados');
      if (btnExcluirSelecionados) {
        btnExcluirSelecionados.onclick = async () => {
          const checkboxes = document.querySelectorAll('.checkbox-delete:checked');
          if (checkboxes.length === 0) {
            alert('Selecione pelo menos um orçamento para excluir.');
            return;
          }
          
          const idsSelecionados = Array.from(checkboxes).map(cb => cb.getAttribute('data-id'));
          const nomes = idsSelecionados.map(id => {
            const item = historicoOrcamentosGlobal.find(i => i.id === id);
            return item ? item.cliente : id;
          }).join(', ');
          
          if (confirm(`⚠️ Confirmar exclusão de ${idsSelecionados.length} orçamento(s)?\n\n${nomes}\n\nEsta ação não pode ser desfeita.`)) {
            showLoading();
            for (const id of idsSelecionados) {
              await deletarOrcamentoDoSupabase(id);
            }
            await carregarHistoricoDoSupabase();
            hideLoading();
            alert(`✅ ${idsSelecionados.length} orçamento(s) excluído(s) com sucesso!`);
            window.renderizarDashboardAdmin();
          }
        };
      }
    }
    
    document.getElementById('adminAccessBtn').addEventListener('click', async () => {
      let atendenteAtual = atendenteSelect?.value;
      
      if (!atendenteAtual || atendenteAtual === '') {
        const usuarioSalvo = localStorage.getItem('usuarioLogado');
        if (usuarioSalvo) {
          try {
            const user = JSON.parse(usuarioSalvo);
            atendenteAtual = user.nome;
            if (atendenteSelect) {
              const optionExists = Array.from(atendenteSelect.options).some(opt => opt.value === atendenteAtual);
              if (optionExists) {
                atendenteSelect.value = atendenteAtual;
              }
            }
          } catch(e) {}
        }
      }
      
      if (!isAtendenteAdmin(atendenteAtual)) {
        alert('⚠️ Acesso negado! O Dashboard Avançado está disponível apenas para atendentes com permissão de administrador.');
        return;
      }
      
      await carregarHistoricoDoSupabase();
      
      const mesesOptions = [];
      const anosSet = new Set();
      historicoOrcamentosGlobal.forEach(item => {
        if (item.dataRaw) {
          const d = new Date(item.dataRaw);
          if (!isNaN(d)) {
            const key = `${d.getFullYear()}-${d.getMonth()+1}`;
            const label = d.toLocaleString('pt-BR', { month: 'long', year: 'numeric' });
            if (!mesesOptions.find(m => m.value === key)) {
              mesesOptions.push({ value: key, label: label });
            }
            anosSet.add(d.getFullYear());
          }
        }
      });
      mesesOptions.sort((a,b) => b.value.localeCompare(a.value));
      const anosOptions = Array.from(anosSet).sort((a,b) => b - a);
      
      let adminModal = document.createElement('div'); adminModal.className = 'modal-overlay';
      adminModal.innerHTML = `
        <div class="modal-content" style="max-width:1300px;">
          <div class="dashboard-container" style="width:100%;">
            <div class="dashboard-header">
              <h1><i class="fas fa-chart-pie"></i> Dashboard Avançado</h1>
              <p style="color:#666; margin-top:8px;">Bem-vinda, ${escapeHtml(atendenteAtual)}!</p>
              <button class="refresh-btn" id="refreshDashboardBtnAdmin"><i class="fas fa-sync-alt"></i> Atualizar Dados</button>
            </div>
            
            <div class="dashboard-tabs">
              <button class="tab-btn active" data-tab="analytics"><i class="fas fa-chart-line"></i> Análises</button>
              <button class="tab-btn" data-tab="atendentes"><i class="fas fa-users"></i> Gerenciar Atendentes</button>
            </div>
            
            <div class="tab-pane active" id="tab-analytics">
              <div class="filter-bar">
                <div class="filter-group">
                  <label>📅 Período:</label>
                  <select id="filtroPeriodo">
                    <option value="todos">Todos os períodos</option>
                    <option value="mes">Mês específico</option>
                    <option value="ano">Ano específico</option>
                  </select>
                </div>
                <div class="filter-group" id="grupoFiltroMes" style="display:none;">
                  <label>📆 Selecionar Mês/Ano:</label>
                  <select id="filtroMes">
                    <option value="">Selecione...</option>
                    ${mesesOptions.map(m => `<option value="${m.value}">${m.label}</option>`).join('')}
                  </select>
                </div>
                <div class="filter-group" id="grupoFiltroAno" style="display:none;">
                  <label>📆 Selecionar Ano:</label>
                  <select id="filtroAno">
                    <option value="">Selecione...</option>
                    ${anosOptions.map(a => `<option value="${a}">${a}</option>`).join('')}
                  </select>
                </div>
                <div class="filter-group">
                  <label>💰 Filtrar por valor:</label>
                  <select id="filtroValorTipo">
                    <option value="todos">Todos</option>
                    <option value="maior">Maior que</option>
                    <option value="menor">Menor que</option>
                    <option value="igual">Igual a</option>
                  </select>
                </div>
                <div class="filter-group">
                  <label>&nbsp;</label>
                  <input type="text" id="filtroValorComp" placeholder="R$ 0,00">
                </div>
                <div class="filter-group">
                  <label>🎂 Idade exata:</label>
                  <input type="text" id="filtroIdade" placeholder="Digite a idade">
                </div>
                <div class="filter-group">
                  <label>👤 Nome do cliente:</label>
                  <input type="text" id="filtroCliente" placeholder="Buscar por nome">
                </div>
                <div class="filter-group">
                  <label>🆔 ID do Orçamento:</label>
                  <input type="text" id="filtroIdOrcamento" placeholder="Buscar por ID">
                </div>
              </div>
              
              <div id="dashboardContent"><div class="empty-state"><i class="fas fa-spinner fa-pulse"></i> Carregando...</div></div>
            </div>
            
            <div class="tab-pane" id="tab-atendentes">
              <div id="gestaoAtendentesContainer"></div>
            </div>
          </div>
          <div class="modal-buttons-row"><button id="closeAdminBtn" class="btn btn-primary">Fechar</button></div>
        </div>
      `;
      document.body.appendChild(adminModal);
      
      const periodoSelect = adminModal.querySelector('#filtroPeriodo');
      const grupoMes = adminModal.querySelector('#grupoFiltroMes');
      const grupoAno = adminModal.querySelector('#grupoFiltroAno');
      
      if (periodoSelect) {
        periodoSelect.addEventListener('change', () => {
          const val = periodoSelect.value;
          if (grupoMes) grupoMes.style.display = val === 'mes' ? 'block' : 'none';
          if (grupoAno) grupoAno.style.display = val === 'ano' ? 'block' : 'none';
          if (window.renderizarDashboardAdmin) window.renderizarDashboardAdmin();
        });
      }
      
      adminModal.querySelector('#filtroMes')?.addEventListener('change', () => { if (window.renderizarDashboardAdmin) window.renderizarDashboardAdmin(); });
      adminModal.querySelector('#filtroAno')?.addEventListener('change', () => { if (window.renderizarDashboardAdmin) window.renderizarDashboardAdmin(); });
      adminModal.querySelector('#filtroValorTipo')?.addEventListener('change', () => { if (window.renderizarDashboardAdmin) window.renderizarDashboardAdmin(); });
      adminModal.querySelector('#filtroValorComp')?.addEventListener('blur', function() {
        this.value = formatMoneyWithThousand(parseCurrency(this.value));
        if (window.renderizarDashboardAdmin) window.renderizarDashboardAdmin();
      });
      adminModal.querySelector('#filtroIdade')?.addEventListener('input', () => { if (window.renderizarDashboardAdmin) window.renderizarDashboardAdmin(); });
      adminModal.querySelector('#filtroCliente')?.addEventListener('input', () => { if (window.renderizarDashboardAdmin) window.renderizarDashboardAdmin(); });
      adminModal.querySelector('#filtroIdOrcamento')?.addEventListener('input', () => { if (window.renderizarDashboardAdmin) window.renderizarDashboardAdmin(); });
      
      const idsUnicos = [...new Set(historicoOrcamentosGlobal.map(item => item.id))];
      const clientesUnicos = [...new Set(historicoOrcamentosGlobal.map(item => item.cliente))];
      
      createSuggestionsDropdown('filtroIdOrcamento', 
        (value) => idsUnicos.filter(id => id.toLowerCase().includes(value)).slice(0, 10),
        (selected) => { if (window.renderizarDashboardAdmin) window.renderizarDashboardAdmin(); }
      );
      
      createSuggestionsDropdown('filtroCliente',
        (value) => clientesUnicos.filter(nome => nome && nome.toLowerCase().includes(value)).slice(0, 10),
        (selected) => { if (window.renderizarDashboardAdmin) window.renderizarDashboardAdmin(); }
      );
      
      adminModal.querySelector('#refreshDashboardBtnAdmin').onclick = async () => {
        await carregarHistoricoDoSupabase();
        if (window.renderizarDashboardAdmin) window.renderizarDashboardAdmin();
        renderizarGestaoAtendentes(adminModal.querySelector('#gestaoAtendentesContainer'));
      };
      
      const dashboardContent = adminModal.querySelector('#dashboardContent');
      if (dashboardContent) {
        dashboardContent.addEventListener('click', (e) => {
          const deleteBtn = e.target.closest('.btn-delete-single');
          if (deleteBtn) {
            e.preventDefault();
            e.stopPropagation();
            const id = deleteBtn.getAttribute('data-id');
            const cliente = deleteBtn.getAttribute('data-cliente');
            if (id && cliente) window.deletarOrcamento(id, cliente);
            return;
          }
          
          const editBtn = e.target.closest('.btn-edit-single');
          if (editBtn) {
            e.preventDefault();
            e.stopPropagation();
            const id = editBtn.getAttribute('data-id');
            const orcamento = historicoOrcamentosGlobal.find(item => item.id === id);
            if (orcamento) {
              adminModal.remove();
              window.editarOrcamento(orcamento);
            }
            return;
          }
          
          const saleBtn = e.target.closest('.btn-sale-single');
          if (saleBtn) {
            e.preventDefault();
            e.stopPropagation();
            const id = saleBtn.getAttribute('data-id');
            const cliente = saleBtn.getAttribute('data-cliente');
            if (id && cliente) window.marcarComoVendaRealizada(id, cliente);
            return;
          }
        });
      }
      
      const tabBtns = adminModal.querySelectorAll('.tab-btn');
      const tabPanes = adminModal.querySelectorAll('.tab-pane');
      tabBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const tabId = btn.getAttribute('data-tab');
          tabBtns.forEach(b => b.classList.remove('active'));
          tabPanes.forEach(p => p.classList.remove('active'));
          btn.classList.add('active');
          const targetPane = adminModal.querySelector(`#tab-${tabId}`);
          if (targetPane) targetPane.classList.add('active');
          
          if (tabId === 'atendentes') {
            renderizarGestaoAtendentes(adminModal.querySelector('#gestaoAtendentesContainer'));
          } else if (tabId === 'analytics' && window.renderizarDashboardAdmin) {
            window.renderizarDashboardAdmin();
          }
        });
      });
      
      if (window.renderizarDashboardAdmin) window.renderizarDashboardAdmin();
      renderizarGestaoAtendentes(adminModal.querySelector('#gestaoAtendentesContainer'));
      
      adminModal.querySelector('#closeAdminBtn').onclick = () => adminModal.remove();
    });
    
    document.getElementById('pesquisaAccessBtn').addEventListener('click', async () => {
      let atendenteAtual = atendenteSelect?.value;
      
      if (!atendenteAtual || atendenteAtual === '') {
        const usuarioSalvo = localStorage.getItem('usuarioLogado');
        if (usuarioSalvo) {
          try {
            const user = JSON.parse(usuarioSalvo);
            atendenteAtual = user.nome;
            if (atendenteSelect) {
              const optionExists = Array.from(atendenteSelect.options).some(opt => opt.value === atendenteAtual);
              if (optionExists) {
                atendenteSelect.value = atendenteAtual;
              }
            }
          } catch(e) {}
        }
      }
      
      if (isAtendenteAdmin(atendenteAtual)) {
        alert('⚠️ Você é administrador(a). Utilize o botão "Área Admin" para acesso completo.');
        return;
      }
      
      await carregarHistoricoDoSupabase();
      
      const mesesOptions = [];
      const anosSet = new Set();
      historicoOrcamentosGlobal.forEach(item => {
        if (item.dataRaw) {
          const d = new Date(item.dataRaw);
          if (!isNaN(d)) {
            const key = `${d.getFullYear()}-${d.getMonth()+1}`;
            const label = d.toLocaleString('pt-BR', { month: 'long', year: 'numeric' });
            if (!mesesOptions.find(m => m.value === key)) {
              mesesOptions.push({ value: key, label: label });
            }
            anosSet.add(d.getFullYear());
          }
        }
      });
      mesesOptions.sort((a,b) => b.value.localeCompare(a.value));
      const anosOptions = Array.from(anosSet).sort((a,b) => b - a);
      
      let pesquisaModal = document.createElement('div'); pesquisaModal.className = 'modal-overlay';
      pesquisaModal.innerHTML = `
        <div class="modal-content" style="max-width:1200px;">
          <div class="dashboard-container" style="width:100%;">
            <div class="dashboard-header">
              <h1><i class="fas fa-search"></i> Pesquisa de Orçamentos</h1>
              <p style="color:#666; margin-top:8px;">Consulta de todos os orçamentos realizados - ${escapeHtml(atendenteAtual)}</p>
              <button class="refresh-btn" id="refreshPesquisaBtn"><i class="fas fa-sync-alt"></i> Atualizar Dados</button>
            </div>
            
            <div class="filter-bar">
              <div class="filter-group">
                <label>📅 Período:</label>
                <select id="pesquisaFiltroPeriodo">
                  <option value="todos">Todos os períodos</option>
                  <option value="mes">Mês específico</option>
                  <option value="ano">Ano específico</option>
                </select>
              </div>
              <div class="filter-group" id="pesquisaGrupoFiltroMes" style="display:none;">
                <label>📆 Selecionar Mês/Ano:</label>
                <select id="pesquisaFiltroMes">
                  <option value="">Selecione...</option>
                  ${mesesOptions.map(m => `<option value="${m.value}">${m.label}</option>`).join('')}
                </select>
              </div>
              <div class="filter-group" id="pesquisaGrupoFiltroAno" style="display:none;">
                <label>📆 Selecionar Ano:</label>
                <select id="pesquisaFiltroAno">
                  <option value="">Selecione...</option>
                  ${anosOptions.map(a => `<option value="${a}">${a}</option>`).join('')}
                </select>
              </div>
              <div class="filter-group">
                <label>💰 Filtrar por valor:</label>
                <select id="pesquisaFiltroValorTipo">
                  <option value="todos">Todos</option>
                  <option value="maior">Maior que</option>
                  <option value="menor">Menor que</option>
                  <option value="igual">Igual a</option>
                </select>
              </div>
              <div class="filter-group">
                <label>&nbsp;</label>
                <input type="text" id="pesquisaFiltroValorComp" placeholder="R$ 0,00">
              </div>
              <div class="filter-group">
                <label>🎂 Idade exata:</label>
                <input type="text" id="pesquisaFiltroIdade" placeholder="Digite a idade">
              </div>
              <div class="filter-group">
                <label>👤 Nome do cliente:</label>
                <input type="text" id="pesquisaFiltroCliente" placeholder="Buscar por nome">
              </div>
              <div class="filter-group">
                <label>🆔 ID do Orçamento:</label>
                <input type="text" id="pesquisaFiltroIdOrcamento" placeholder="Buscar por ID">
              </div>
            </div>
            
            <div id="pesquisaContent"><div class="empty-state"><i class="fas fa-spinner fa-pulse"></i> Carregando...</div></div>
          </div>
          <div class="modal-buttons-row"><button id="closePesquisaBtn" class="btn btn-primary">Fechar</button></div>
        </div>
      `;
      document.body.appendChild(pesquisaModal);
      
      const periodoSelect = pesquisaModal.querySelector('#pesquisaFiltroPeriodo');
      const grupoMes = pesquisaModal.querySelector('#pesquisaGrupoFiltroMes');
      const grupoAno = pesquisaModal.querySelector('#pesquisaGrupoFiltroAno');
      
      if (periodoSelect) {
        periodoSelect.addEventListener('change', () => {
          const val = periodoSelect.value;
          if (grupoMes) grupoMes.style.display = val === 'mes' ? 'block' : 'none';
          if (grupoAno) grupoAno.style.display = val === 'ano' ? 'block' : 'none';
          renderizarPesquisaOrcamentos();
        });
      }
      
      pesquisaModal.querySelector('#pesquisaFiltroMes')?.addEventListener('change', () => renderizarPesquisaOrcamentos());
      pesquisaModal.querySelector('#pesquisaFiltroAno')?.addEventListener('change', () => renderizarPesquisaOrcamentos());
      pesquisaModal.querySelector('#pesquisaFiltroValorTipo')?.addEventListener('change', () => renderizarPesquisaOrcamentos());
      pesquisaModal.querySelector('#pesquisaFiltroValorComp')?.addEventListener('blur', function() {
        this.value = formatMoneyWithThousand(parseCurrency(this.value));
        renderizarPesquisaOrcamentos();
      });
      pesquisaModal.querySelector('#pesquisaFiltroIdade')?.addEventListener('input', () => renderizarPesquisaOrcamentos());
      pesquisaModal.querySelector('#pesquisaFiltroCliente')?.addEventListener('input', () => renderizarPesquisaOrcamentos());
      pesquisaModal.querySelector('#pesquisaFiltroIdOrcamento')?.addEventListener('input', () => renderizarPesquisaOrcamentos());
      
      const idsUnicos = [...new Set(historicoOrcamentosGlobal.map(item => item.id))];
      const clientesUnicos = [...new Set(historicoOrcamentosGlobal.map(item => item.cliente))];
      
      createSuggestionsDropdown('pesquisaFiltroIdOrcamento', 
        (value) => idsUnicos.filter(id => id.toLowerCase().includes(value)).slice(0, 10),
        (selected) => renderizarPesquisaOrcamentos()
      );
      
      createSuggestionsDropdown('pesquisaFiltroCliente',
        (value) => clientesUnicos.filter(nome => nome && nome.toLowerCase().includes(value)).slice(0, 10),
        (selected) => renderizarPesquisaOrcamentos()
      );
      
      pesquisaModal.querySelector('#refreshPesquisaBtn').onclick = async () => {
        await carregarHistoricoDoSupabase();
        renderizarPesquisaOrcamentos();
      };
      
      const pesquisaContent = pesquisaModal.querySelector('#pesquisaContent');
      if (pesquisaContent) {
        pesquisaContent.addEventListener('click', (e) => {
          const deleteBtn = e.target.closest('.btn-delete-single-pesquisa');
          if (deleteBtn) {
            e.preventDefault();
            e.stopPropagation();
            const id = deleteBtn.getAttribute('data-id');
            const cliente = deleteBtn.getAttribute('data-cliente');
            if (id && cliente) window.deletarOrcamento(id, cliente);
            return;
          }
          
          const editBtn = e.target.closest('.btn-edit-single-pesquisa');
          if (editBtn) {
            e.preventDefault();
            e.stopPropagation();
            const id = editBtn.getAttribute('data-id');
            const orcamento = historicoOrcamentosGlobal.find(item => item.id === id);
            if (orcamento) {
              pesquisaModal.remove();
              window.editarOrcamento(orcamento);
            }
            return;
          }
          
          const saleBtn = e.target.closest('.btn-sale-single-pesquisa');
          if (saleBtn) {
            e.preventDefault();
            e.stopPropagation();
            const id = saleBtn.getAttribute('data-id');
            const cliente = saleBtn.getAttribute('data-cliente');
            if (id && cliente) window.marcarComoVendaRealizada(id, cliente);
            return;
          }
        });
      }
      
      renderizarPesquisaOrcamentos();
      
      pesquisaModal.querySelector('#closePesquisaBtn').onclick = () => pesquisaModal.remove();
    });
    
    window.addEventListener('beforeunload', (e) => {
      e.preventDefault();
      e.returnValue = '';
    });
  })();
</script>
</body>
</html>
