    async function salvarHistorico(status, justificativa='') {
      let orcamentoData = {
        id: currentOrcamentoId,
        dataRaw: new Date().toISOString(),
        atendente: atendenteSelect.value,
        cliente: clientName.value.trim(),
        idade: clientAge.value.trim(),
        telefone: clientPhone.value.trim(),
        origem: clientSource.value,
        concorrente: clientSource.value === 'Concorrente' ? document.getElementById('concorrenteNome').value.trim() : '',
        itens: JSON.parse(JSON.stringify(orcamentos)),
        subtotal: calcularSubtotalItens(),
        descontoGeral: parseCurrency(descontoGeralInput?.value),
        totalFinal: calcularTotalFinal(),
        status: status,
        justificativa: justificativa
      };
      
      const salvou = await salvarComFallback(orcamentoData);
      
      if (salvou) {
        if (modoEdicao && orcamentoEditandoId) {
          modoEdicao = false;
          orcamentoEditandoId = null;
        }
        localStorage.removeItem('orcamentosTemp');
        localStorage.removeItem('nextIdTemp');
        return true;
      }
      return false;
    }
    
