      const container = document.getElementById('resumoItensList'); 
      if(!container) return;
      container.innerHTML = '';
      let idx=1;
      for(let item of orcamentos){
        let descricao='', valorBase=0, descontoItem=item.descontoItem||0;
        if(item.tipo==='lente'){ 
          let extras = [];
          if(item.antirreflexo) extras.push('AR');
          if(item.filtroLuzAzul) extras.push('Filtro Azul');
          if(item.lenteFotocromatica) extras.push('Fotocromática');
          descricao=`${item.produto||'Lente'} ${item.marca?`·${item.marca}`:''} ${item.materialLente?`(${item.materialLente})`:''} ${extras.length?`[${extras.join(', ')}]`:''}`; 
          valorBase=item.valorLente||0; 
        }
        else if(item.tipo==='armacao') { 
          descricao=`${item.marca?`${item.marca}`:'Armação'} ${item.referencia?`Ref: ${item.referencia}`:''}`; 
          valorBase=item.valorArmacao||0; 
        }
        else if(item.tipo==='relogio') {
          descricao=`${item.nomeRelogio||'Relógio'} ${item.marcaRelogio?`(${item.marcaRelogio})`:''}`;
          valorBase=item.valorRelogio||0;
        }
        else if(item.tipo==='joias') {
          descricao=`${item.descricaoJoia||'Joia'} ${item.tipoJoia?`(${item.tipoJoia})`:''}`;
          valorBase=item.valorJoia||0;
        }
        let valorLiq = Math.max(0,valorBase-descontoItem);
        let div = document.createElement('div'); div.className='summary-item';
        div.innerHTML = `<span class="summary-label">${idx++}. ${descricao}${descontoItem>0?` <span style="color:#e74c3c;">(desc:R$ ${formatMoneyWithThousand(descontoItem)})</span>`:''}</span><span class="summary-value">${formatMoneyWithSymbol(valorLiq)}</span>`;
