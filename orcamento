    function verificarUsuarioLogado() {
      const usuarioSalvo = localStorage.getItem('usuarioLogado');
      if (usuarioSalvo) {
        try {
          const user = JSON.parse(usuarioSalvo);
          const timestamp = new Date(user.loginTimestamp);
          const agora = new Date();
          const diffHoras = (agora - timestamp) / (1000 * 60 * 60);
          
          if (diffHoras > 8) {
            localStorage.removeItem('usuarioLogado');
            return false;
          }
          
          const nomeAtendente = user.nome;
          const atendenteAtivo = atendentes.find(a => a.nome === nomeAtendente && a.ativo === true);
          
          if (atendenteAtivo) {
            atendenteSelect.value = nomeAtendente;
            const changeEvent = new Event('change', { bubbles: true });
            atendenteSelect.dispatchEvent(changeEvent);
            
            if (validateStep1()) {
              jaPassouStep1 = true;
              setTimeout(() => {
                goToStep(2);
              }, 50);
            }
            return true;
          }
          return false;
        } catch(e) {
          console.error('Erro ao ler usuário logado:', e);
          localStorage.removeItem('usuarioLogado');
          return false;
        }
      }
      return false;
    }
    
